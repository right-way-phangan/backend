# Own Postgres. Local dev: a Docker/Homebrew Postgres. Prod: localhost on the VPS.
DATABASE_URL=postgres://rightway:rightway@localhost:5432/rightway
PG_POOL_MAX=10

# Source for the one-time migrations (reuse the existing project token).
AMOCRM_DOMAIN=rightwaykpg.amocrm.ru
AMOCRM_TOKEN=
AMOCRM_OBJECTS_CATALOG_ID=9077

# Optional: map amoCRM lead pipelines → our (land / villa_house) for migrate:leads.
# If unset, the script maps by pipeline name heuristic.
AMOCRM_PIPELINE_LAND=
AMOCRM_PIPELINE_VILLA_HOUSE=
