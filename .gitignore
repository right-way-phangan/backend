# api/index.js is the esbuild bundle (the Vercel function). It is COMMITTED so
# git auto-deploy has the function present without relying on Vercel to run the
# build (Vercel classifies this layout as static and skips it). `npm run build`
# regenerates it; rebuild + commit when src/api changes.
